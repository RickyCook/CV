{
  "name": "cv",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://thatpanda.com",
  "dependencies": {
    "lodash": "^4.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typeface-overpass-mono": "^1.1.13",
    "typeface-share-tech-mono": "^1.1.13"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--openssl-legacy-provider vite",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "fmt": "biome format --write .",
    "typecheck": "tsc --noEmit && npm --prefix pdf run typecheck",
    "build": "npm run build-html && npm run build-pdf",
    "build-html": "NODE_OPTIONS=--openssl-legacy-provider vite build && NODE_OPTIONS=--openssl-legacy-provider vite build --ssr src/entry-server.tsx --outDir build-server && node scripts/prerender.mjs",
    "build-pdf": "cd pdf && npm run build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "motion": "^12.42.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  }
}
